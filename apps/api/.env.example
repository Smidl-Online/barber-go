# Database — PostgreSQL connection string
# V Coolify: nastav jako Environment Variable
DATABASE_URL="postgresql://postgres:barbergo@localhost:5432/barbergo?schema=public"

# JWT secrets — změň na náhodné řetězce!
JWT_SECRET="your-secret-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"

# Port (Coolify nastaví automaticky)
PORT=3000

# Seed DB při prvním startu (nastav "true" jen poprvé, pak vypni)
SEED_DB=false
