{
  "expo": {
    "name": "BarberGo",
    "slug": "barber-go",
    "platforms": [
      "ios",
      "android"
    ],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "barbergo",
    "splash": {
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cz.barbergo.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "cz.barbergo.app"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/78e8b6e6-dff6-4b94-9789-d78e72ded15a"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "apiUrl": "https://barbergo-dev-api.coolify.smidl.online",
      "eas": {
        "projectId": "78e8b6e6-dff6-4b94-9789-d78e72ded15a"
      }
    }
  }
}
